{
  "name": "@pozalabs/pori",
  "version": "0.5.6",
  "description": "Audio library for React — waveform visualization, HLS streaming, and playlist management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pozalabs/pori.git"
  },
  "homepage": "https://github.com/pozalabs/pori",
  "keywords": [
    "audio",
    "react",
    "waveform",
    "player",
    "playlist",
    "hls"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./components": {
      "require": {
        "types": "./dist/components.d.ts",
        "default": "./dist/components.js"
      },
      "import": {
        "types": "./dist/components.d.mts",
        "default": "./dist/components.mjs"
      },
      "default": {
        "types": "./dist/components.d.ts",
        "default": "./dist/components.js"
      }
    },
    "./hooks": {
      "require": {
        "types": "./dist/hooks.d.ts",
        "default": "./dist/hooks.js"
      },
      "import": {
        "types": "./dist/hooks.d.mts",
        "default": "./dist/hooks.mjs"
      },
      "default": {
        "types": "./dist/hooks.d.ts",
        "default": "./dist/hooks.js"
      }
    },
    "./utils": {
      "require": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      },
      "import": {
        "types": "./dist/utils.d.mts",
        "default": "./dist/utils.mjs"
      },
      "default": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      }
    }
  },
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "test": "vitest --run",
    "coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write --cache .",
    "prepack": "bun run build"
  },
  "files": [
    "dist",
    "components.d.ts",
    "hooks.d.ts",
    "utils.d.ts"
  ],
  "devDependencies": {
    "@eslint/compat": "^1.1.1",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.9.0",
    "@testing-library/dom": "^10.3.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/eslint": "^9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/webaudioapi": "^0.0.27",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.3",
    "autoprefixer": "^10.4.19",
    "blob-polyfill": "^9.0.20240710",
    "clsx": "^2.1.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "globals": "^15.9.0",
    "jsdom": "^24.1.0",
    "msw": "^2.3.1",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "standardized-audio-context-mock": "^9.7.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.6",
    "tsup": "^8.1.0",
    "typescript": "~5.4.5",
    "vite": "^5.3.4",
    "vitest": "^2.0.3",
    "vitest-canvas-mock": "^0.3.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "hls.js": "^1.5.18"
  }
}
